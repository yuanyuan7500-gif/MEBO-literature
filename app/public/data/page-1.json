ublication":"右江民族医学院学报","year":2000,"volume":"","issue":"03","pages":"462","doi":"","pmid":"","keywords":["剖宫产","会阴","切口"],"keywordsEn":[],"itemType":"journalArticle","language":"zh","isOA":false,"citations":0,"aiSummary":"","tags":["剖宫产","会阴","切口"],"dateAdded":"2025-01-07","entities":[]},{"id":"88","title":"湿润烧伤膏治疗褥疮26例","titleEn":"","authors":["缪金莲"],"abstract":"","abstractEn":"","publication":"时珍国医国药","year":2000,"volume":"","issue":"06","pages":"494","doi":"","pmid":"","keywords":[],"keywordsEn":[],"itemType":"journalArticle","language":"zh","isOA":false,"citations":0,"aiSummary":"","tags":[],"dateAdded":"2025-01-07","entities":[]},{"id":"89","title":"湿润烧伤膏获得生产批号","titleEn":"","authors":[],"abstract":"","abstractEn":"","publication":"中国中医药信息杂志","year":2000,"volume":"","issue":"05","pages":"55","doi":"","pmid":"","keywords":[],"keywordsEn":[],"itemType":"journalArticle","language":"zh","isOA":false,"citations":0,"aiSummary":"","tags":[],"dateAdded":"2025-01-07","entities":[]},{"id":"90","title":"湿润烧伤膏治疗眼睑带状疱疹30例","titleEn":"","authors":["曹征"],"abstract":"<正> 眼睑带状疱疹是一种较为严重的眼睑病,从1994年以来,我们应用湿润烧伤膏联合聚肌胞等治疗此病,取得满意的临床效果,现介绍如下。 1 临床资料 1.1 一般资料:本组共30例,其中男25例,女5例;右眼18例,左眼12例;年龄:8～65岁;并发角膜炎5例,虹膜睫状体炎2例;患者神经痛显著,皮疹分布在上睑及前额部皮肤,为群集性粟粒状或绿豆大小丘疹,","abstractEn":"","publication":"医学理论与实践","year":2000,"volume":"","issue":"05","pages":"266","doi":"10.19381/j.issn.1001-7585.2000.05.005","pmid":"","keywords":[],"keywordsEn":[],"itemType":"journalArticle","language":"zh","isOA":false,"citations":0,"aiSummary":"","tags":[],"dateAdded":"2025-01-07","entities":[]},{"id":"91","title":"湿润烧伤膏治疗新生儿脓疱疮43例报告","titleEn":"","authors":["沈可英"],"abstract":"","abstractEn":"","publication":"农垦医学","year":2000,"volume":"","issue":"02","pages":"115","doi":"","pmid":"","keywords":[],"keywordsEn":[],"itemType":"journalArticle","language":"zh","isOA":false,"citations":0,"aiSummary":"","tags":[],"dateAdded":"2025-01-07","entities":[]},{"id":"92","title":"湿润烧伤膏致过敏性皮炎一例","titleEn":"","authors":["蒋志军"],"abstract":"<正> 某患者,女,左手前臂外侧被高压锅喷出蒸气烫伤,约3×4cm2大小,局部充血,有少量水泡,诊断为浅2度烫伤,即给予湿润烧伤膏外涂患处。次日,患者诉患者搔痒,检查伤口无异常变化,继续用药。用药后不久搔痒加剧,患部起大泡,伤口周围出现密集的红色小丘疹,考虑为外用药引起的接触性皮炎,遂停用湿润烧伤膏,清创后改用利凡诺纱条湿敷患部。次日搔痒减","abstractEn":"","publication":"实用医技","year":2000,"volume":"","issue":"04","pages":"10","doi":"","pmid":"","keywords":["⛔️"],"keywordsEn":[],"itemType":"journalArticle","language":"zh","isOA":false,"citations":0,"aiSummary":"","tags":["⛔️"],"dateAdded":"2025-01-07","entities":[]},{"id":"93","title":"医药成果","titleEn":"","authors":[],"abstract":"<正> 北京伤口愈合研究世界领先 由北京光明中医烧伤创疡研究所独创的烧伤湿润医疗技术及其湿润烧伤膏对烧伤伤口愈合疗效好,目前被公认达到了世界领先水平。","abstractEn":"","publication":"上海医药","year":2000,"volume":"","issue":"04","pages":"42-43","doi":"","pmid":"","keywords":[],"keywordsEn":[],"itemType":"journalArticle","language":"zh","isOA":false,"citations":0,"aiSummary":"","tags":[],"dateAdded":"2025-01-07","entities":[]},{"id":"94","title":"湿润烧伤膏治疗褥疮的护理体会","titleEn":"","authors":["毛小萍"],"abstract":"","abstractEn":"","publication":"黑龙江护理杂志","year":2000,"volume":"","issue":"04","pages":"8","doi":"","pmid":"","keywords":[],"keywordsEn":[],"itemType":"journalArticle","language":"zh","isOA":false,"citations":0,"aiSummary":"","tags":[],"dateAdded":"2025-01-07","entities":[]},{"id":"95","title":"湿润烧伤膏治疗隐翅虫皮炎疗效观察","titleEn":"","authors":["吴飞"],"abstract":"","abstractEn":"","publication":"中国皮肤性病学杂志","year":2000,"volume":"","issue":"01","pages":"76","doi":"","pmid":"","keywords":[],"keywordsEn":[],"itemType":"journalArticle","language":"zh","isOA":false,"citations":0,"aiSummary":"","tags":[],"dateAdded":"2025-01-07","entities":[]},{"id":"96","title":"湿润烧伤膏加云南白药治疗鼻粘膜溃疡","titleEn":"","authors":["张琴","张雯"],"abstract":"鼻粘膜溃疡多因外伤、手术创伤、鼻腔填塞、鼻中隔偏曲、化学刺激、特殊感染引起,有的迁延不愈可引起长期反复鼻出血.我们应用湿润膏加云南白药治疗收到非常好的疗效,现总结如下.","abstractEn":"","publication":"海峡药学","year":2000,"volume":"12","issue":"z1","pages":"34 %K","doi":"","pmid":"","keywords":[],"keywordsEn":[],"itemType":"journalArticle","language":"zh","isOA":false,"citations":0,"aiSummary":"","tags":[],"dateAdded":"2025-01-07","entities":[]},{"id":"97","title":"大面积烧伤病人使用美宝致败血症5例","titleEn":"","authors":["张连和"],"abstract":"","abstractEn":"","publication":"实用临床医学","year":2000,"volume":"14","issue":"3","pages":"41","doi":"","pmid":"","keywords":["%X","烧伤","败血症","感染"],"keywordsEn":[],"itemType":"journalArticle","language":"zh","isOA":false,"citations":0,"aiSummary":"","tags":["%X","烧伤","败血症","感染"],"dateAdded":"2025-01-07","entities":[]},{"id":"98","title":"尤脱欣综合治疗尖锐湿疣66例报告","titleEn":"","authors":["谭建华","吕本祝","刘艳玲"],"abstract":"尖锐湿疣(CA)为人类乳头瘤病毒(HPV)感染所致,是目前常见的性传播疾病之一,临床易反复发作,难以根治.我们采用外用尤脱欣(0.5%鬼臼毒素酊)、湿润烧伤膏,结合搔刮术、CO2激光气化综合治疗66例,取得较好疗效.报道如下.","abstractEn":"","publication":"中国临床药理学与治疗学","year":2000,"volume":"5","issue":"3","pages":"276 %K","doi":"","pmid":"","keywords":[],"keywordsEn":[],"itemType":"journalArticle","language":"zh","isOA":false,"citations":0,"aiSummary":"","tags":[],"dateAdded":"2025-01-07","entities":[]},{"id":"99","title":"创伤病人术后伤口暴露疗法初探","titleEn":"","authors":["夏群","金鸿宾","万春友","陈新","范玉强"],"abstract":"传统的创伤科手术术后伤口均采用无菌纱布敷盖,定期换药直至伤口拆线,但仍有部分伤口发生感染.随着湿润暴露疗法(MEBT)治疗创伤创面的成功报道[1,2],使得创伤科传统的伤口处理方法受到挑战.本文即探讨创伤病人术后伤口采用暴露疗法的可能性及优势.","abstractEn":"","publication":"中国骨伤","year":2000,"volume":"13","issue":"5","pages":"281 %K","doi":"","pmid":"","keywords":[],"keywordsEn":[],"itemType":"journalArticle","language":"zh","isOA":false,"citations":0,"aiSummary":"","tags":[],"dateAdded":"2025-01-07","entities":[]},{"id":"100","title":"烧伤皮肤再生创新成就发布大会致辞","titleEn":"","authors":["马俊如"],"abstract":"各位尊敬的来宾、女士们、先生们: 下午好! 我和在座的各位一样,是以非常高兴的心情出席今天的烧伤皮肤再生创新成就发布会,祝贺徐荣祥教授在烧伤皮肤干细胞再生研究中获得重要突破!我还要借此机会代表徐荣祥教授向出席今天发布会的所有朋友表示感谢!","abstractEn":"","publication":"中国烧伤创疡杂志","year":2000,"volume":"","issue":"3 %V","pages":"3-5 %K","doi":"","pmid":"","keywords":["📢"],"keywordsEn":[],"itemType":"journalArticle","language":"zh","isOA":false,"citations":0,"aiSummary":"","tags":["📢"],"dateAdded":"2025-01-07","entities":[]}]